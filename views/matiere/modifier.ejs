<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier la matière</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/navbar'); %>

    <div class="container mt-5">
        <h1 class="mb-4">Modifier la matière</h1>

        <form id="modifierForm">
            <div class="mb-3">
                <label for="nom" class="form-label">Nom</label>
                <input type="text" class="form-control" id="nom" required>
            </div>

            <button type="submit" class="btn btn-primary">Modifier</button>
        </form>

        <div id="message" class="mt-3"></div>
        <a href="/matiere" class="btn btn-secondary mt-3">Retour à la liste</a>
    </div>

    <script>
        const form = document.getElementById('modifierForm');
        const messageDiv = document.getElementById('message');

        // Récupérer l'ID de la matière depuis l'URL
        const urlParts = window.location.pathname.split('/');
        const matiereId = urlParts[urlParts.length - 1];

        // Fonction pour pré-remplir le formulaire
        async function loadMatiere() {
            try {
                const res = await fetch(`/api/matiere/${matiereId}`);
                const matiere = await res.json();

                document.getElementById('nom').value = matiere.nom|| '';
            } catch (err) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
            }
        }

        // Envoi du formulaire pour modifier la matière
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const matiereData = {
                nom: document.getElementById('nom').value || ''
            };

            try {
                const response = await fetch(`/api/matiere/${matiereId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(matiereData)
                });

                if (response.ok) {
                    messageDiv.innerHTML = `<div class="alert alert-success">Matière modifiée avec succès !</div>`;
                } else {
                    const err = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
                }
            } catch (error) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${error.message}</div>`;
            }
        });

        // Charger la matière au chargement de la page
        loadMatiere();
    </script>

  <%- include('../partials/footer'); %>
</html>
