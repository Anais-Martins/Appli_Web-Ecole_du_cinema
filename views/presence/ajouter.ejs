<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ajouter une présence</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <!-- Navbar incluse -->
    <%- include('../partials/navbar'); %>

    <div class="container mt-5">
        <h1 class="mb-4">Ajouter une présence</h1>

        <form id="ajouterForm">

            <div class="mb-3">
                <label for="presence" class="form-label">Présence</label>
                <input type="boolean" class="form-control" id="presence" >
            </div>

            <div class="mb-3">
                <label for="id_cours" class="form-label">Id cours</label>
                <input type="number" class="form-control" id="id_cours" >
            </div>

            <div class="mb-3">
                <label for="id_apprenant" class="form-label">Id apprenant</label>
                <input type="number" class="form-control" id="id_apprenant" >
            </div>


            <button type="submit" class="btn btn-primary">Ajouter</button>
        </form>

        <div id="message" class="mt-3"></div>
    </div>

    <script>
        const form = document.getElementById('ajouterForm');
        const messageDiv = document.getElementById('message');

        form.addEventListener('submit', async (e) => {
            e.preventDefault(); // Empêche l’envoi classique

            const presenceData = {
                presence: document.getElementById('presence').value,
                id_cours: document.getElementById('id_cours').value,
                id_apprenant: document.getElementById('id_apprenant').value,
            };

            try {
                const response = await fetch('/api/presence', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(presenceData)
                });

                if (response.ok) {
                    const result = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-success">Présence ajoutée avec succès !</div>`;
                    form.reset();
                } else {
                    const err = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
                }
            } catch (error) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${error.message}</div>`;
            }
        });
    </script>

   <%- include('../partials/footer'); %>
</body>
</html>
