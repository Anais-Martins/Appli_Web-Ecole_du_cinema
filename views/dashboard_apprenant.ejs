<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Mon espace – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <main>
    <section class="dashboard-apprenant-section">
      <h2 class="dashboard-titre">Mon espace</h2>

      <!-- Boutons de navigation -->
      <div class="dashboard-apprenant-nav">
        <button class="btn-onglet actif" onclick="afficherOnglet('cours', this)">Cours</button>
        <button class="btn-onglet" onclick="afficherOnglet('notes', this)">Notes</button>
        <button class="btn-onglet" onclick="afficherOnglet('formateurs', this)">Formateurs</button>
        <button class="btn-onglet" onclick="afficherOnglet('avis', this)">Avis</button>
      </div>

      <!-- Onglet Cours -->
      <div id="onglet-cours" class="onglet-content">
        <div class="liste-wrapper">
          <table class="liste-table">
            <thead>
              <tr>
                <th>Matière</th>
                <th>Date</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Présence</th>
              </tr>
            </thead>
            <tbody id="coursTable">
              <tr><td colspan="5" class="liste-vide">Chargement...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Onglet Notes -->
      <div id="onglet-notes" class="onglet-content" style="display:none">
        <div class="liste-wrapper">
          <table class="liste-table">
            <thead>
              <tr>
                <th>Matière</th>
                <th>Note</th>
                <th>Date</th>
                <th>Type d'évaluation</th>
              </tr>
            </thead>
            <tbody id="notesTable">
              <tr><td colspan="4" class="liste-vide">Chargement...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Onglet Formateurs -->
      <div id="onglet-formateurs" class="onglet-content" style="display:none">
        <div class="liste-wrapper">
          <table class="liste-table">
            <thead>
              <tr>
                <th>Prénom</th>
                <th>Nom</th>
                <th>E-mail</th>
                <th>Matière</th>
              </tr>
            </thead>
            <tbody id="formateursTable">
              <tr><td colspan="4" class="liste-vide">Chargement...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Onglet Avis -->
      <div id="onglet-avis" class="onglet-content" style="display:none">
        <div class="avis-wrapper">
          <div id="avis-existant" style="display:none">
            <div class="avis-card">
              <div class="avis-card-header">Mon avis</div>
              <div class="avis-card-body">
                <p id="avis-formation-nom" class="avis-formation"></p>
                <p id="avis-contenu" class="avis-contenu"></p>
                <div class="avis-btns">
                  <button class="btn-table-modifier" onclick="afficherFormulaireModif()">Modifier</button>
                  <button class="btn-table-supprimer-orange" onclick="supprimerAvis()">Supprimer</button>
                </div>
              </div>
            </div>
          </div>

          <div id="avis-formulaire">
            <div class="formulaire-card">
              <div class="formulaire-card-header" id="avis-form-titre">Laisser un avis</div>
              <div class="formulaire-card-body">
                <div id="avis-message"></div>
                <div class="formulaire-champ">
                  <label for="avis-formation">Formation</label>
                  <select id="avis-formation" class="formulaire-select">
                    <option value="">-- Sélectionner une formation --</option>
                  </select>
                </div>
                <div class="formulaire-champ">
                  <label for="avis-contenu-input">Votre avis</label>
                  <textarea id="avis-contenu-input" class="formulaire-textarea"
                    placeholder="Partagez votre expérience..."></textarea>
                </div>
                <div class="formulaire-footer">
                  <button class="btn-formulaire-submit" onclick="soumettreAvis()">Envoyer</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Récupérer id_apprenant depuis le token stocké en cookie (décodé côté serveur via EJS)
    const idApprenant = <%= user ? user.id_apprenant : 'null' %>;
    let avisId = null;
    let modeModif = false;

    // --- Navigation onglets ---
    function afficherOnglet(nom, btn) {
      document.querySelectorAll('.onglet-content').forEach(el => el.style.display = 'none');
      document.querySelectorAll('.btn-onglet').forEach(el => el.classList.remove('actif'));
      document.getElementById('onglet-' + nom).style.display = 'block';
      btn.classList.add('actif');
    }

    // --- Cours + présences ---
    async function fetchCours() {
      try {
        const [coursRes, presenceRes] = await Promise.all([
          fetch(`/api/apprenant/${idApprenant}/cours`),
          fetch(`/api/apprenant/${idApprenant}/presences`)
        ]);
        const cours = await coursRes.json();
        const presences = await presenceRes.json();

        const tbody = document.getElementById('coursTable');
        if (!cours.length) {
          tbody.innerHTML = `<tr><td colspan="5" class="liste-vide">Aucun cours trouvé</td></tr>`;
          return;
        }

        const today = new Date();
        tbody.innerHTML = '';
        cours.forEach(c => {
          const matiere = c.matiere ? c.matiere.nom : '—';
          const date = c.date ? new Date(c.date) : null;
          const dateStr = date ? date.toLocaleDateString('fr-FR') : '—';
          const debut = c.horaire_debut ? c.horaire_debut.substring(0, 5) : '—';
          const fin = c.horaire_fin ? c.horaire_fin.substring(0, 5) : '—';

          const presence = presences.find(p => p.id_cours === c.id_cours);
          let presenceStr = '—';
          if (date && date > today) {
            presenceStr = '<span class="badge-futur">À venir</span>';
          } else if (presence) {
            presenceStr = presence.presence
              ? '<span class="badge-present">Présent</span>'
              : '<span class="badge-absent">Absent</span>';
          }

          tbody.innerHTML += `
            <tr>
              <td>${matiere}</td>
              <td>${dateStr}</td>
              <td>${debut}</td>
              <td>${fin}</td>
              <td>${presenceStr}</td>
            </tr>`;
        });
      } catch (err) {
        document.getElementById('coursTable').innerHTML =
          `<tr><td colspan="5" class="liste-vide">Erreur : ${err.message}</td></tr>`;
      }
    }

    // --- Notes ---
    async function fetchNotes() {
      try {
        const res = await fetch(`/api/apprenant/${idApprenant}/notes`);
        const notes = await res.json();
        const tbody = document.getElementById('notesTable');

        if (!notes.length) {
          tbody.innerHTML = `<tr><td colspan="4" class="liste-vide">Aucune note trouvée</td></tr>`;
          return;
        }

        tbody.innerHTML = '';
        notes.forEach(n => {
          const matiere = n.matiere ? n.matiere.nom : '—';
          const date = n.date ? new Date(n.date).toLocaleDateString('fr-FR') : '—';
          tbody.innerHTML += `
            <tr>
              <td>${matiere}</td>
              <td>${n.note}</td>
              <td>${date}</td>
              <td>${n.type_eval || '—'}</td>
            </tr>`;
        });
      } catch (err) {
        document.getElementById('notesTable').innerHTML =
          `<tr><td colspan="4" class="liste-vide">Erreur : ${err.message}</td></tr>`;
      }
    }

    // --- Formateurs ---
    async function fetchFormateurs() {
      try {
        const res = await fetch(`/api/apprenant/${idApprenant}/formateurs`);
        const formateurs = await res.json();
        const tbody = document.getElementById('formateursTable');

        if (!formateurs.length) {
          tbody.innerHTML = `<tr><td colspan="4" class="liste-vide">Aucun formateur trouvé</td></tr>`;
          return;
        }

        tbody.innerHTML = '';
        formateurs.forEach(f => {
          tbody.innerHTML += `
            <tr>
              <td>${f.prenom}</td>
              <td>${f.nom}</td>
              <td>${f.email || '—'}</td>
              <td>${f.matiere || '—'}</td>
            </tr>`;
        });
      } catch (err) {
        document.getElementById('formateursTable').innerHTML =
          `<tr><td colspan="4" class="liste-vide">Erreur : ${err.message}</td></tr>`;
      }
    }

    // --- Avis ---
    async function fetchAvis() {
      try {
        // Charger les formations pour le select
        const formRes = await fetch('/api/formation');
        const formData = await formRes.json();
        const formations = formData.formations || formData;
        const select = document.getElementById('avis-formation');
        formations.forEach(f => {
          select.innerHTML += `<option value="${f.id_formation}">${f.nom}</option>`;
        });

        // Chercher un avis existant de cet apprenant
        const avisRes = await fetch(`/api/apprenant/${idApprenant}/avis`);
        const avisData = await avisRes.json();

        if (avisData && avisData.id_avis) {
          avisId = avisData.id_avis;
          document.getElementById('avis-existant').style.display = 'block';
          document.getElementById('avis-formulaire').style.display = 'none';
          document.getElementById('avis-formation-nom').textContent =
            avisData.Formation ? avisData.Formation.nom : '';
          document.getElementById('avis-contenu').textContent = avisData.contenu;
        }
      } catch (err) {
        console.error('Erreur avis :', err.message);
      }
    }

    function afficherFormulaireModif() {
      modeModif = true;
      document.getElementById('avis-existant').style.display = 'none';
      document.getElementById('avis-formulaire').style.display = 'block';
      document.getElementById('avis-form-titre').textContent = 'Modifier mon avis';
      document.getElementById('avis-contenu-input').value =
        document.getElementById('avis-contenu').textContent;
    }

    async function soumettreAvis() {
      const messageDiv = document.getElementById('avis-message');
      const contenu = document.getElementById('avis-contenu-input').value;
      const id_formation = document.getElementById('avis-formation').value;

      if (!contenu || (!modeModif && !id_formation)) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Veuillez remplir tous les champs.</p>`;
        return;
      }

      try {
        const url = modeModif ? `/api/avis/${avisId}` : '/api/avis';
        const method = modeModif ? 'PUT' : 'POST';
        const body = modeModif
          ? { contenu }
          : { id_apprenant: idApprenant, id_formation, contenu };

        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Avis enregistré !</p>`;
          setTimeout(() => location.reload(), 1000);
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (err) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
      }
    }

    async function supprimerAvis() {
      if (!confirm('Voulez-vous vraiment supprimer votre avis ?')) return;
      try {
        const response = await fetch(`/api/avis/${avisId}`, { method: 'DELETE' });
        if (response.ok) location.reload();
        else alert('Erreur lors de la suppression.');
      } catch (err) {
        alert('Erreur : ' + err.message);
      }
    }

    // Chargement initial
    fetchCours();
    fetchNotes();
    fetchFormateurs();
    fetchAvis();
  </script>
</body>
</html>
