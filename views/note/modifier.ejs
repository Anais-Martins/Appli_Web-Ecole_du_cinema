<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier la note</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<%- include('../partials/navbar'); %>

<div class="container mt-5">
    <h1 class="mb-4">Modifier la note</h1>

    <form id="modifierForm">
        <div class="mb-3">
            <label for="apprenant" class="form-label">Apprenant</label>
            <select id="apprenant" class="form-select" required>
                <% apprenant.forEach(e => { %>
                    <option value="<%= e.id %>" <%= note && note.id_apprenant === e.id ? 'selected' : '' %>>
                        <%= e.nom %> <%= e.prenom %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="mb-3">
            <label for="cours" class="form-label">Cours</label>
            <select id="cours" class="form-select" required>
                <% cours.forEach(c => { %>
                    <option value="<%= c.id %>" <%= note && note.id_cours === c.id ? 'selected' : '' %>>
                        <%= c.nom %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="mb-3">
            <label for="note" class="form-label">Note</label>
            <input type="number" step="0.01" class="form-control" id="note" required
                   value="<%= note ? note.note : '' %>">
        </div>

        <button type="submit" class="btn btn-primary">Modifier</button>
    </form>

    <div id="message" class="mt-3"></div>
    <a href="/note/" class="btn btn-secondary mt-3">Retour à la liste</a>
</div>

<script>
    // ⚠️ Vérifie que note existe
    const noteId = "<%= note ? note.id : '' %>";

    const form = document.getElementById('modifierForm');
    const messageDiv = document.getElementById('message');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const noteData = {
            id_apprenant: document.getElementById('apprenant').value,
            id_cours: document.getElementById('cours').value,
            note: document.getElementById('note').value
        };

        try {
            const res = await fetch(`/api/note/${noteId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(noteData)
            });

            if (res.ok) {
                messageDiv.innerHTML = `<div class="alert alert-success">Note modifiée avec succès !</div>`;
            } else {
                const err = await res.json();
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
            }
        } catch (err) {
            messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
        }
    });
</script>

<%- include('../partials/footer'); %>
</body>
</html>
