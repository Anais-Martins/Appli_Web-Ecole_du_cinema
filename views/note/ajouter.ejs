<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Ajouter une note</title>
  <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar'); %>

  <div class="container mt-5">
    <h1 class="mb-4">Ajouter une note</h1>

    <form id="ajouterForm">
      <div class="mb-3">
        <label for="apprenant" class="form-label">Apprenant</label>
        <select class="form-select" id="apprenant" required>
          <option value="">-- Sélectionner --</option>
          <% apprenant.forEach(e => { %>
            <option value="<%= e.id %>"><%= e.nom %> <%= e.prenom %></option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="cours" class="form-label">Cours</label>
        <select class="form-select" id="cours" required>
          <option value="">-- Sélectionner --</option>
          <% cours.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.nom %></option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="note" class="form-label">Note</label>
        <input type="number" step="0.01" class="form-control" id="note" required>
      </div>

      <div class="mb-3">
        <label for="date" class="form-label">Date</label>
        <input type="date" step="0.01" class="form-control" id="date" required>
      </div>

      <div class="mb-3">
        <label for="type_eval" class="form-label">Type d'évaluation</label>
        <input type="enum" step="0.01" class="form-control" id="type_eval" required>
      </div>

      <div class="mb-3">
        <label for="id_matiere" class="form-label">Id matière</label>
        <input type="number" step="0.01" class="form-control" id="id_matiere" required>
      </div>

      <button type="submit" class="btn btn-primary">Ajouter</button>
    </form>

    <div id="message" class="mt-3"></div>
  </div>

  <script>
    const form = document.getElementById('ajouterForm');
    const messageDiv = document.getElementById('message');

    form.addEventListener('submit', async e => {
      e.preventDefault();

      const noteData = {
        id_apprenant: document.getElementById('apprenant').value,
        id_cours: document.getElementById('cours').value,
        note: document.getElementById('note').value
      };

      try {
        const res = await fetch('/api/note', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(noteData)
        });

        if (res.ok) {
          messageDiv.innerHTML = `<div class="alert alert-success">Note ajoutée !</div>`;
          form.reset();
        } else {
          const err = await res.json();
          messageDiv.innerHTML = `<div class="alert alert-danger">${err.message}</div>`;
        }
      } catch (err) {
        messageDiv.innerHTML = `<div class="alert alert-danger">${err.message}</div>`;
      }
    });
  </script>

  <%- include('../partials/footer'); %>
</body>
</html>
