<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ajouter un avis</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <!-- Navbar incluse -->
    <%- include('../partials/navbar'); %>

    <div class="container mt-5">
        <h1 class="mb-4">Ajouter un avis</h1>

        <form id="ajouterForm">
            <div class="mb-3">
                <label for="id_avis" class="form-label">Id Avis</label>
                <input type="number" class="form-control" id="id_avis" required>
            </div>

            <div class="mb-3">
                <label for="contenu" class="form-label">Contenu</label>
                <input type="text" class="form-control" id="contenu" required>
            </div>

            <div class="mb-3">
                <label for="id_formation" class="form-label">Id formation</label>
                <input type="number" class="form-control" id="id_formation" required>
            </div>

            <div class="mb-3">
                <label for="id_apprenant" class="form-label">Id apprenant</label>
                <input type="number" class="form-control" id="id_apprenant" >
            </div>


            <button type="submit" class="btn btn-primary">Ajouter</button>
        </form>

        <div id="message" class="mt-3"></div>
    </div>

    <script>
        const form = document.getElementById('ajouterForm');
        const messageDiv = document.getElementById('message');

        form.addEventListener('submit', async (e) => {
            e.preventDefault(); // Empêche l’envoi classique

            const avisData = {
                contenu: document.getElementById('contenu').value,
                id_formation: document.getElementById('id_formation').value,
                id_apprenant: document.getElementById('id_apprenant').value,
            };

            try {
                const response = await fetch('/api/avis', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(avisData)
                });

                if (response.ok) {
                    const result = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-success">Avis ajouté avec succès !</div>`;
                    form.reset();
                } else {
                    const err = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
                }
            } catch (error) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${error.message}</div>`;
            }
        });
    </script>

   <%- include('../partials/footer'); %>
</body>
</html>
