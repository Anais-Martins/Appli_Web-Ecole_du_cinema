<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ajouter un cours – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="formulaire-section">
      <div class="formulaire-card">
        <div class="formulaire-card-header">Ajouter un cours</div>
        <div class="formulaire-card-body">

          <div id="message"></div>

          <div class="formulaire-champ">
            <label for="id_matiere">Matière</label>
            <select id="id_matiere" class="formulaire-select">
              <option value="">-- Sélectionner une matière --</option>
              <% matiere.forEach(m => { %>
                <option value="<%= m.id_matiere %>"><%= m.nom %></option>
              <% }) %>
            </select>
          </div>

          <div class="formulaire-champ">
            <label for="date">Date</label>
            <input type="date" id="date">
          </div>

          <div class="formulaire-champ">
            <label for="horaire_debut">Horaire de début</label>
            <input type="time" id="horaire_debut">
          </div>

          <div class="formulaire-champ">
            <label for="horaire_fin">Horaire de fin</label>
            <input type="time" id="horaire_fin">
          </div>

          <div class="formulaire-footer">
            <a href="/cours/liste" class="btn-formulaire-retour">← Retour</a>
            <button class="btn-formulaire-submit" onclick="ajouterCours()">Ajouter</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    async function ajouterCours() {
      const messageDiv = document.getElementById('message');
      const data = {
        id_matiere: document.getElementById('id_matiere').value,
        date: document.getElementById('date').value,
        horaire_debut: document.getElementById('horaire_debut').value,
        horaire_fin: document.getElementById('horaire_fin').value,
      };

      if (!data.id_matiere || !data.date || !data.horaire_debut || !data.horaire_fin) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Veuillez remplir tous les champs.</p>`;
        return;
      }

      try {
        const response = await fetch('/api/cours', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Cours ajouté avec succès !</p>`;
          document.getElementById('id_matiere').value = '';
          document.getElementById('date').value = '';
          document.getElementById('horaire_debut').value = '';
          document.getElementById('horaire_fin').value = '';
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (error) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${error.message}</p>`;
      }
    }
  </script>
</body>
</html>
