<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Modifier un cours – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="formulaire-section">
      <div class="formulaire-card">
        <div class="formulaire-card-header">Modifier un cours</div>
        <div class="formulaire-card-body">

          <div id="message"></div>

          <div class="formulaire-champ">
            <label for="id_matiere">Matière</label>
            <select id="id_matiere" class="formulaire-select">
              <% matiere.forEach(m => { %>
                <option value="<%= m.id_matiere %>"
                  <%= cours.id_matiere === m.id_matiere ? 'selected' : '' %>>
                  <%= m.nom %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="formulaire-champ">
            <label for="date">Date</label>
            <input type="date" id="date"
              value="<%= cours.date ? new Date(cours.date).toISOString().split('T')[0] : '' %>">
          </div>

          <div class="formulaire-champ">
            <label for="horaire_debut">Horaire de début</label>
            <input type="time" id="horaire_debut"
              value="<%= cours.horaire_debut ? cours.horaire_debut.substring(0, 5) : '' %>">
          </div>

          <div class="formulaire-champ">
            <label for="horaire_fin">Horaire de fin</label>
            <input type="time" id="horaire_fin"
              value="<%= cours.horaire_fin ? cours.horaire_fin.substring(0, 5) : '' %>">
          </div>

          <div class="formulaire-footer">
            <a href="/cours/liste" class="btn-formulaire-retour">← Retour</a>
            <button class="btn-formulaire-submit" onclick="modifierCours()">Enregistrer</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const urlParts = window.location.pathname.split('/');
    const coursId = urlParts[urlParts.length - 1];
    const messageDiv = document.getElementById('message');

    async function modifierCours() {
      const data = {
        id_matiere: document.getElementById('id_matiere').value,
        date: document.getElementById('date').value,
        horaire_debut: document.getElementById('horaire_debut').value,
        horaire_fin: document.getElementById('horaire_fin').value,
      };

      try {
        const response = await fetch(`/api/cours/${coursId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Cours modifié avec succès !</p>`;
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (error) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${error.message}</p>`;
      }
    }
  </script>
</body>
</html>
