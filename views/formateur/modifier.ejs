<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Modifier un formateur – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="formulaire-section">
      <div class="formulaire-card">
        <div class="formulaire-card-header">Modifier un formateur</div>
        <div class="formulaire-card-body">

          <div id="message"></div>

          <div class="formulaire-champ">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom">
          </div>
          <div class="formulaire-champ">
            <label for="nom">Nom</label>
            <input type="text" id="nom">
          </div>
          <div class="formulaire-champ">
            <label for="email">E-mail</label>
            <input type="email" id="email">
          </div>
          <div class="formulaire-champ">
            <label for="telephone">Téléphone</label>
            <input type="text" id="telephone">
          </div>
          <div class="formulaire-champ">
            <label for="info_complementaires">Informations complémentaires</label>
            <input type="text" id="info_complementaires">
          </div>

          <div class="formulaire-footer">
            <a href="/formateur" class="btn-formulaire-retour">← Retour</a>
            <button class="btn-formulaire-submit" onclick="modifierFormateur()">Enregistrer</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const urlParts = window.location.pathname.split('/');
    const formateurId = urlParts[urlParts.length - 1];
    const messageDiv = document.getElementById('message');

    async function loadFormateur() {
      try {
        const res = await fetch(`/api/formateur/${formateurId}`);
        const f = await res.json();
        document.getElementById('prenom').value = f.prenom || '';
        document.getElementById('nom').value = f.nom || '';
        document.getElementById('email').value = f.email || '';
        document.getElementById('telephone').value = f.telephone || '';
        document.getElementById('info_complementaires').value = f.info_complementaires || '';
      } catch (err) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur chargement : ${err.message}</p>`;
      }
    }

    async function modifierFormateur() {
      const formateurData = {
        prenom: document.getElementById('prenom').value,
        nom: document.getElementById('nom').value,
        email: document.getElementById('email').value,
        telephone: document.getElementById('telephone').value,
        info_complementaires: document.getElementById('info_complementaires').value || ''
      };

      try {
        const response = await fetch(`/api/formateur/${formateurId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formateurData)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Formateur modifié avec succès !</p>`;
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (error) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${error.message}</p>`;
      }
    }

    loadFormateur();
  </script>
</body>
</html>
