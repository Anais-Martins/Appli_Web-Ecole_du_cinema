<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ajouter un formateur – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="formulaire-section">
      <div class="formulaire-card">
        <div class="formulaire-card-header">Ajouter un formateur</div>
        <div class="formulaire-card-body">

          <div id="message"></div>

          <div class="formulaire-champ">
            <label for="prenom">Prénom</label>
            <input type="text" id="prenom" placeholder="Prénom du formateur">
          </div>
          <div class="formulaire-champ">
            <label for="nom">Nom</label>
            <input type="text" id="nom" placeholder="Nom du formateur">
          </div>
          <div class="formulaire-champ">
            <label for="email">E-mail</label>
            <input type="email" id="email" placeholder="adresse@email.com">
          </div>
          <div class="formulaire-champ">
            <label for="telephone">Téléphone</label>
            <input type="text" id="telephone" placeholder="06 00 00 00 00">
          </div>
          <div class="formulaire-champ">
            <label for="info_complementaires">Informations complémentaires</label>
            <input type="text" id="info_complementaires" placeholder="Spécialité, notes...">
          </div>

          <div class="formulaire-footer">
            <a href="/formateur" class="btn-formulaire-retour">← Retour</a>
            <button class="btn-formulaire-submit" onclick="ajouterFormateur()">Ajouter</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    async function ajouterFormateur() {
      const messageDiv = document.getElementById('message');
      const formateurData = {
        prenom: document.getElementById('prenom').value,
        nom: document.getElementById('nom').value,
        email: document.getElementById('email').value,
        telephone: document.getElementById('telephone').value,
        info_complementaires: document.getElementById('info_complementaires').value,
      };

      try {
        const response = await fetch('/api/formateur', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formateurData)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Formateur ajouté avec succès !</p>`;
          document.querySelectorAll('input').forEach(i => i.value = '');
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (error) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${error.message}</p>`;
      }
    }
  </script>
</body>
</html>
