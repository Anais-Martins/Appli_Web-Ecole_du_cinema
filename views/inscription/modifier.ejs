<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Modifier une inscription – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="formulaire-section">
      <div class="formulaire-card">
        <div class="formulaire-card-header">Modifier une inscription</div>
        <div class="formulaire-card-body">

          <div id="message"></div>

          <div class="formulaire-champ">
            <label for="id_apprenant">Apprenant</label>
            <select id="id_apprenant" class="formulaire-select">
              <% apprenant.forEach(a => { %>
                <option value="<%= a.id_apprenant %>"
                  <%= inscription.id_apprenant === a.id_apprenant ? 'selected' : '' %>>
                  <%= a.prenom %> <%= a.nom %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="formulaire-champ">
            <label for="id_formation">Formation</label>
            <select id="id_formation" class="formulaire-select">
              <% formation.forEach(f => { %>
                <option value="<%= f.id_formation %>"
                  <%= inscription.id_formation === f.id_formation ? 'selected' : '' %>>
                  <%= f.nom %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="formulaire-champ">
            <label for="date">Date d'inscription</label>
            <input type="date" id="date" value="<%= inscription.date ? new Date(inscription.date).toISOString().split('T')[0] : '' %>">
          </div>

          <div class="formulaire-footer">
            <a href="/inscription" class="btn-formulaire-retour">← Retour</a>
            <button class="btn-formulaire-submit" onclick="modifierInscription()">Enregistrer</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const urlParts = window.location.pathname.split('/');
    const inscriptionId = urlParts[urlParts.length - 1];
    const messageDiv = document.getElementById('message');

    async function modifierInscription() {
      const data = {
        id_apprenant: document.getElementById('id_apprenant').value,
        id_formation: document.getElementById('id_formation').value,
        date: document.getElementById('date').value,
      };

      try {
        const response = await fetch(`/api/inscription/${inscriptionId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Inscription modifiée avec succès !</p>`;
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (error) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${error.message}</p>`;
      }
    }
  </script>
</body>
</html>
