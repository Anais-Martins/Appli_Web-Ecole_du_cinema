<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Ajouter une inscription – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="formulaire-section">
      <div class="formulaire-card">
        <div class="formulaire-card-header">Ajouter une inscription</div>
        <div class="formulaire-card-body">

          <div id="message"></div>

          <div class="formulaire-champ">
            <label for="id_apprenant">Apprenant</label>
            <select id="id_apprenant" class="formulaire-select">
              <option value="">-- Sélectionner un apprenant --</option>
              <% apprenant.forEach(a => { %>
                <option value="<%= a.id_apprenant %>"><%= a.prenom %> <%= a.nom %></option>
              <% }) %>
            </select>
          </div>

          <div class="formulaire-champ">
            <label for="id_formation">Formation</label>
            <select id="id_formation" class="formulaire-select">
              <option value="">-- Sélectionner une formation --</option>
              <% formation.forEach(f => { %>
                <option value="<%= f.id_formation %>"><%= f.nom %></option>
              <% }) %>
            </select>
          </div>

          <div class="formulaire-champ">
            <label for="date">Date d'inscription</label>
            <input type="date" id="date">
          </div>

          <div class="formulaire-footer">
            <a href="/inscription" class="btn-formulaire-retour">← Retour</a>
            <button class="btn-formulaire-submit" onclick="ajouterInscription()">Ajouter</button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    async function ajouterInscription() {
      const messageDiv = document.getElementById('message');
      const data = {
        id_apprenant: document.getElementById('id_apprenant').value,
        id_formation: document.getElementById('id_formation').value,
        date: document.getElementById('date').value,
      };

      if (!data.id_apprenant || !data.id_formation || !data.date) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Veuillez remplir tous les champs.</p>`;
        return;
      }

      try {
        const response = await fetch('/api/inscription', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          messageDiv.innerHTML = `<p class="formulaire-succes">Inscription ajoutée avec succès !</p>`;
          document.getElementById('id_apprenant').value = '';
          document.getElementById('id_formation').value = '';
          document.getElementById('date').value = '';
        } else {
          const err = await response.json();
          messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${err.message}</p>`;
        }
      } catch (error) {
        messageDiv.innerHTML = `<p class="formulaire-erreur">Erreur : ${error.message}</p>`;
      }
    }
  </script>
</body>
</html>
