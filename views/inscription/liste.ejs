<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Inscriptions – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>
    <section class="liste-section">
      <div class="liste-header">
        <h2 class="liste-titre">Inscriptions</h2>
        <div class="liste-actions">
          <input id="searchInput" type="text" placeholder="Rechercher..." class="liste-search" oninput="fetchInscriptions(1)">
          <a href="/inscription/ajouter" class="btn-liste-ajouter">+ Ajouter</a>
        </div>
      </div>

      <div class="liste-wrapper">
        <table class="liste-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Apprenant</th>
              <th>Formation</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="inscriptionTable">
          </tbody>
        </table>

        <nav class="liste-pagination">
          <ul id="pagination"></ul>
        </nav>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let currentPage = 1;
    let totalPages = 1;

    async function fetchInscriptions(page = 1) {
      try {
        const searchTerm = document.getElementById('searchInput').value || '';
        const response = await fetch(`/api/inscription?page=${page}&limit=10&search=${encodeURIComponent(searchTerm)}`);
        const result = await response.json();
        if (!response.ok) throw new Error(result.message || 'Erreur serveur.');

        const inscriptions = result.inscription || [];
        totalPages = result.pagination?.totalPages || 1;
        currentPage = result.pagination?.page || 1;

        renderTable(inscriptions);
        renderPagination();
      } catch (error) {
        document.getElementById('inscriptionTable').innerHTML =
          `<tr><td colspan="5" class="liste-vide">Erreur : ${error.message}</td></tr>`;
      }
    }

    function renderTable(inscriptions) {
      const tbody = document.getElementById('inscriptionTable');
      tbody.innerHTML = '';

      if (!inscriptions.length) {
        tbody.innerHTML = `<tr><td colspan="5" class="liste-vide">Aucune inscription trouvée</td></tr>`;
        return;
      }

      inscriptions.forEach(i => {
        const apprenant = i.apprenant ? `${i.apprenant.prenom} ${i.apprenant.nom}` : '—';
        const formation = i.formation ? i.formation.nom : '—';
        const date = i.date ? new Date(i.date).toLocaleDateString('fr-FR') : '—';

        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${i.id_inscription}</td>
          <td>${apprenant}</td>
          <td>${formation}</td>
          <td>${date}</td>
          <td class="liste-btns">
            <a href="/inscription/modifier/${i.id_inscription}" class="btn-table-modifier">Modifier</a>
            <button class="btn-table-supprimer-orange" onclick="supprimerInscription(${i.id_inscription})">Supprimer</button>
          </td>
        `;
        tbody.appendChild(row);
      });
    }

    function renderPagination() {
      const container = document.getElementById('pagination');
      container.innerHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        const li = document.createElement('li');
        li.className = i === currentPage ? 'actif' : '';
        li.innerHTML = `<button onclick="fetchInscriptions(${i})">${i}</button>`;
        container.appendChild(li);
      }
    }

    async function supprimerInscription(id) {
      if (!confirm('Voulez-vous vraiment supprimer cette inscription ?')) return;
      try {
        const response = await fetch(`/api/inscription/${id}`, { method: 'DELETE' });
        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.message || 'Erreur suppression');
        }
        fetchInscriptions(currentPage);
      } catch (err) {
        alert('Erreur : ' + err.message);
      }
    }

    fetchInscriptions();
  </script>
</body>
</html>
