<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier la formation</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/navbar'); %>

    <div class="container mt-5">
        <h1 class="mb-4">Modifier la formation</h1>

        <form id="modifierForm">
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <input type="text" class="form-control" id="description" required>
            </div>

            <button type="submit" class="btn btn-primary">Modifier</button>
        </form>

        <div id="message" class="mt-3"></div>
        <a href="/formation" class="btn btn-secondary mt-3">Retour à la liste</a>
    </div>

    <script>
        const form = document.getElementById('modifierForm');
        const messageDiv = document.getElementById('message');

        // Récupérer l'ID de la formation depuis l'URL
        const urlParts = window.location.pathname.split('/');
        const formationId = urlParts[urlParts.length - 1];

        // Fonction pour pré-remplir le formulaire
        async function loadFormation() {
            try {
                const res = await fetch(`/api/formation/${formationId}`);
                const formation = await res.json();

                document.getElementById('nom').value = formation.nom;
                document.getElementById('description').value = formation.description|| '';
            } catch (err) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
            }
        }

        // Envoi du formulaire pour modifier la formation
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formationData = {
                nom: document.getElementById('nom').value,
                description: document.getElementById('description').value || ''
            };

            try {
                const response = await fetch(`/api/formation/${formationId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formationData)
                });

                if (response.ok) {
                    messageDiv.innerHTML = `<div class="alert alert-success">Formation modifiée avec succès !</div>`;
                } else {
                    const err = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
                }
            } catch (error) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${error.message}</div>`;
            }
        });

        // Charger la formation au chargement de la page
        loadFormation();
    </script>

  <%- include('../partials/footer'); %>
</html>
