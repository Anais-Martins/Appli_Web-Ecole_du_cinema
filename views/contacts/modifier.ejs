<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Modifier le contact</title>
  <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
</head>
<body>
  <%- include('../partials/navbar'); %>

  <div class="container mt-5">
    <h1 class="mb-4">Modifier le contact</h1>

    <form id="modifierForm" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="nom" class="form-label">Nom</label>
        <input type="text" id="nom" name="nom" class="form-control" required value="<%= contact.nom %>">
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" class="form-control" required value="<%= contact.email %>">
      </div>

      <div class="mb-3">
        <label for="telephone" class="form-label">Téléphone</label>
        <input type="text" id="telephone" name="telephone" class="form-control" value="<%= contact.telephone %>">
      </div>

      <div class="mb-3">
        <label for="photo" class="form-label">Photo</label>
        <input type="file" id="photo" name="photo" class="form-control">
        <% if(contact.photo){ %>
          <img src="/uploads/<%= contact.photo %>" width="50" class="mt-2">
        <% } %>
      </div>

      <div class="mb-3">
        <label for="fichier" class="form-label">Fichier</label>
        <input type="file" id="fichier" name="fichier" class="form-control">
        <% if(contact.fichier){ %>
          <a href="/uploads/<%= contact.fichier %>" target="_blank">Télécharger</a>
        <% } %>
      </div>

      <button type="submit" class="btn btn-primary">Modifier</button>
    </form>

    <div id="message" class="mt-3"></div>
    <a href="/contacts" class="btn btn-secondary mt-3">Retour à la liste</a>
  </div>

  <script>
    const form = document.getElementById('modifierForm');
    const messageDiv = document.getElementById('message');

    // Récupérer l'ID depuis l'URL
    const urlParts = window.location.pathname.split('/');
    const contactId = urlParts[urlParts.length - 1];

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      try {
        const res = await fetch(`/api/contacts/${contactId}`, {
          method: 'PUT',
          body: formData
        });
        const data = await res.json();

        if (res.ok) {
          messageDiv.innerHTML = '<div class="alert alert-success">Contact modifié avec succès !</div>';
        } else {
          messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${data.message}</div>`;
        }
      } catch (err) {
        messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
      }
    });
  </script>

  <%- include('../partials/footer'); %>
</body>
</html>
