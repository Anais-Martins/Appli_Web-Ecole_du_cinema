<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier la salle</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/navbar'); %>

    <div class="container mt-5">
        <h1 class="mb-4">Modifier la salle</h1>

        <form id="modifierForm">
            <div class="mb-3">
                <label for="numero" class="form-label">Numéro</label>
                <input type="number" class="form-control" id="numero" required>
            </div>

            <button type="submit" class="btn btn-primary">Modifier</button>
        </form>

        <div id="message" class="mt-3"></div>
        <a href="/salle" class="btn btn-secondary mt-3">Retour à la liste</a>
    </div>

    <script>
        const form = document.getElementById('modifierForm');
        const messageDiv = document.getElementById('message');

        // Récupérer l'ID de la salle depuis l'URL
        const urlParts = window.location.pathname.split('/');
        const salleId = urlParts[urlParts.length - 1];

        // Fonction pour pré-remplir le formulaire
        async function loadSalle() {
            try {
                const res = await fetch(`/api/salle/${salleId}`);
                const salle = await res.json();

                document.getElementById('numero').value = salle.numero|| '';
            } catch (err) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
            }
        }

        // Envoi du formulaire pour modifier la salle
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const salleData = {
                numero: document.getElementById('numero').value || ''
            };

            try {
                const response = await fetch(`/api/salle/${salleId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(salleData)
                });

                if (response.ok) {
                    messageDiv.innerHTML = `<div class="alert alert-success">Salle modifiée avec succès !</div>`;
                } else {
                    const err = await response.json();
                    messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${err.message}</div>`;
                }
            } catch (error) {
                messageDiv.innerHTML = `<div class="alert alert-danger">Erreur : ${error.message}</div>`;
            }
        });

        // Charger la salle au chargement de la page
        loadSalle();
    </script>

  <%- include('../partials/footer'); %>
</html>
