<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard Admin – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <main>
    <section class="dashboard-section">
      <h2 class="dashboard-titre">Espace administrateur</h2>

      <div class="dashboard-grid">

        <!-- Formateurs -->
        <div class="dashboard-card">
          <div class="dashboard-card-header">Formateurs</div>
          <div class="dashboard-card-body">
            <p>Gérer la liste des formateurs de l'école.</p>
            <a href="/formateur" class="btn-dashboard">Afficher</a>
          </div>
        </div>

        <!-- Apprenants -->
        <div class="dashboard-card">
          <div class="dashboard-card-header">Apprenants</div>
          <div class="dashboard-card-body">
            <p>Gérer la liste des apprenants inscrits.</p>
            <a href="/apprenant" class="btn-dashboard">Afficher</a>
          </div>
        </div>

        <!-- Inscriptions -->
        <div class="dashboard-card">
          <div class="dashboard-card-header">Inscriptions</div>
          <div class="dashboard-card-body">
            <p>Consulter et gérer les inscriptions aux formations.</p>
            <a href="/inscription" class="btn-dashboard">Afficher</a>
          </div>
        </div>

        <!-- Cours -->
        <div class="dashboard-card">
          <div class="dashboard-card-header">Cours</div>
          <div class="dashboard-card-body">
            <p>Gérer les cours et leur planification.</p>
            <a href="/cours" class="btn-dashboard">Afficher</a>
          </div>
        </div>

        <!-- Users -->
        <div class="dashboard-card">
          <div class="dashboard-card-header">Utilisateurs</div>
          <div class="dashboard-card-body">
            <p>Créer un nouveau compte utilisateur.</p>
            <a href="/register" class="btn-dashboard">Créer</a>
          </div>
        </div>

      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
