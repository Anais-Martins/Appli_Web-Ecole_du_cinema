<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Contact – Ecole du Cinéma de Toulouse</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <main>
    <section class="contact-section">
      <h2 class="contact-titre">Nous contacter</h2>

      <div class="contact-card">
        <div class="contact-card-header">Coordonnées</div>
        <div class="contact-card-body">
          <p class="contact-ligne">
            <span class="contact-label">Adresse</span>
            <span>9 Rue des Amidonniers, 31000 Toulouse</span>
          </p>
          <p class="contact-ligne">
            <span class="contact-label">Quartier</span>
            <span>Proche Place Saint-Pierre</span>
          </p>
          <p class="contact-ligne">
            <span class="contact-label">Téléphone</span>
            <span>05 06 07 08 09</span>
          </p>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
