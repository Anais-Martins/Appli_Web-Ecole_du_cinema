<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Formations – Ecole du Cinéma de Toulouse</title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <!-- CSS personnalisé -->
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <%- include('partials/navbar') %>

  <main>
    <section class="formations-section">
      <h2 class="formations-titre">Nos formations</h2>

      <div class="formations-wrapper">

        <!-- Réalisation -->
        <div class="formation-card">
          <div class="formation-left">
            <div class="formation-card-header">Réalisation</div>
            <div class="formation-card-body">
              <p>Formation complète aux métiers de la réalisation cinématographique.
              Maîtrise de la direction d'acteurs, du cadrage, de la lumière, du montage
              narratif et de la préparation technique d'un tournage.</p>
            </div>
          </div>
          <div class="formation-right">
            <div class="formation-right-titre">Cours &amp; formateurs</div>
            <table class="formation-table">
              <tr><td>Cadrage et composition</td><td>Wes Anderson</td></tr>
              <tr><td>Direction d'acteurs</td><td>Xavier Dolan</td></tr>
              <tr><td>Montage narratif</td><td>Lana Wachowski</td></tr>
              <tr><td>Lumière et atmosphère</td><td>Greta Gerwig</td></tr>
              <tr><td>Préparation et découpage technique</td><td>Alfred Hitchcock</td></tr>
            </table>
          </div>
        </div>

        <!-- Acting -->
        <div class="formation-card">
          <div class="formation-left">
            <div class="formation-card-header">Acting</div>
            <div class="formation-card-body">
              <p>Formation intensive au jeu d'acteur pour la caméra et la scène.
              Travail approfondi sur les techniques d'interprétation, la gestion des émotions,
              la préparation physique et vocale du personnage, et l'improvisation.</p>
            </div>
          </div>
          <div class="formation-right">
            <div class="formation-right-titre">Cours &amp; formateurs</div>
            <table class="formation-table">
              <tr><td>Techniques d'improvisation</td><td>Meryl Streep</td></tr>
              <tr><td>Exploration des émotions</td><td>Florence Pugh</td></tr>
              <tr><td>Préparation physique du personnage</td><td>Marina Foïs</td></tr>
              <tr><td>Travail vocal et diction</td><td>Viola Davis</td></tr>
              <tr><td>Jeu face caméra</td><td>Leïla Bekhti</td></tr>
            </table>
          </div>
        </div>

        <!-- Scénarisation -->
        <div class="formation-card">
          <div class="formation-left">
            <div class="formation-card-header">Scénarisation</div>
            <div class="formation-card-body">
              <p>Formation à l'écriture de scénarios pour le cinéma et les séries.
              Apprentissage de la structure narrative, du développement des personnages,
              de l'écriture de dialogues, de l'adaptation et des techniques de réécriture.</p>
            </div>
          </div>
          <div class="formation-right">
            <div class="formation-right-titre">Cours &amp; formateurs</div>
            <table class="formation-table">
              <tr><td>Structure en trois actes</td><td>Christopher Nolan</td></tr>
              <tr><td>Développement des personnages</td><td>Martin Scorsese</td></tr>
              <tr><td>Dialogues et sous-texte</td><td>Marcel Pagnol</td></tr>
              <tr><td>Adaptation littéraire</td><td>Denis Villeneuve</td></tr>
              <tr><td>Réécriture et script-doctoring</td><td>Alain Chabat</td></tr>
            </table>
          </div>
        </div>

      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
